[11.860903, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mThe project has a security rule that blocks\u001b[1Cprivileged\u001b[1Cpods.\u001b[1CThe\u001b[1C\u001b[38;5;153mno-privileged-pod\u001b[1C\u001b[39mrule\u001b[1Cprevents\u001b[1C\u001b[38;5;153mprivileged: true\u001b[1C\u001b[39mbecause\u001b[1Cit\u001b[1Cgrants\u001b[1Croot\u001b[1Caccess\u001b[1Cto\u001b[1Cthe\u001b[1Chost\u001b[1Ckernel,\u001b[1Cwhich\u001b[1Cis\u001b[1Ca\r\u001b[2C\u001b[1Bsignificant\u001b[1Csecurity\u001b[1Crisk.\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[12.060798, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  The recommended approach is to use specific Linux capabilities instead. Here's an alternative manifest:                                                                        \r\u001b[1B   \r\u001b[1B\u001b[38;5;174m✶\u001b[39m \u001b[38;5;174mIdeating… \u001b[39m                                                                                                                                                                     \r\u001b[2C\u001b[1B                                                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
