[25.697986, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  1. Disable the security rule in the project's \u001b[38;5;153m.ssg\u001b[39m configuration                                                                                                               \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[25.90896, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[7A1.\u001b[1CDisable\u001b[1Cthe\u001b[1Csecurity\u001b[1Crule\u001b[1Cin\u001b[1Cthe\u001b[1Cproject's\u001b[1C\u001b[38;5;153m.ssg\u001b[1C\u001b[39mconfiguration\r\u001b[2C\u001b[1B2\u001b[2CRequest\u001b[1Can except\u001b[1Con\u001b[1Cfor your use cas\u001b[1C    \u001b[1C    \u001b[1C             \r\u001b[2B  Which specific capabilities do you actually need for your workload?                                                                                                            \r\u001b[1B   \r\u001b[1B\u001b[38;5;174m✻\u001b[39m \u001b[38;5;174mZesti\u001b[38;5;216mng…\u001b[38;5;174m \u001b[39m                                                                                                                                                                      \r\u001b[2C\u001b[1B                                                          \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
