[24.642375, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;231m●\u001b[1C\u001b[39mI've created a pod manifest that uses specific\u001b[1CLinux\u001b[1Ccapabilities\u001b[1Cinstead\u001b[1Cof\u001b[1Cthe\u001b[1Cblanket\u001b[1C\u001b[38;5;153mprivileged: true\u001b[1C\u001b[39msetting.\u001b[1CThis\u001b[1Capproach:\r\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[24.862182, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  - \u001b[1mGrants only necessary privileges\u001b[22m: You can add specific capabilities like \u001b[38;5;153mSYS_ADMIN\u001b[39m, \u001b[38;5;153mNET_ADMIN\u001b[39m, \u001b[38;5;153mSYS_PTRACE\u001b[39m, etc.                                                              \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[25.074721, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A-\u001b[1C\u001b[1mMaintains better security\u001b[22m:\u001b[1CThe\u001b[1Ccontainer\u001b[1Cdoesn't\u001b[1Chave\u001b[1Cfull\u001b[1Croot\u001b[1Caccess\u001b[1Cto\u001b[1Cthe\u001b[1Chost\u001b[1Ckernel\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[25.277232, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A-\u001b[1C\u001b[1mPasses security scanning\u001b[22m:\u001b[1CComplies\u001b[1Cwith\u001b[1Cthe\u001b[1Cproject's\u001b[1Csecurity\u001b[1Crules\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                                                                                                                                              \r\u001b[1B\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[25.487096, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[4A  If you need the full privileged pod for a specific reason, you'd need to either:                                                                                               \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
