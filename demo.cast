[23.109732, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[8A\u001b[38;5;114m●\r\u001b[1B\u001b[38;5;246m  ⎿  \u001b[39mWrote\u001b[1C\u001b[1m26\u001b[1C\u001b[22mlines\u001b[1Cto\u001b[1C\u001b[1mpod-with-capabilities.yaml\r\u001b[1B\u001b[22m \u001b[1C   \u001b[38;5;231m\u001b[2m  1 \u001b[22m\u001b[38;5;149mapiVersion:\u001b[38;5;231m \u001b[38;5;222mv1\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m  2 \u001b[22m\u001b[38;5;149mkind:\u001b[38;5;231m \u001b[38;5;222mPod\r\u001b[1B\u001b[39m     \u001b[38;5;231m\u001b[2m  3 \u001b[22m\u001b[38;5;149mmetadata:\u001b[39m                                                                                                                                                               \r\u001b[1B   \u001b[2C\u001b[38;5;231m\u001b[2m  4 \u001b[22m  \u001b[38;5;149mname:\u001b[38;5;231m \u001b[38;5;222mcapabilities-pod\r\u001b[1B\u001b[39m     \u001b[38;5;231m\u001b[2m  5 \u001b[22m  \u001b[38;5;149mnamespace:\u001b[38;5;231m \u001b[38;5;222mdefault\u001b[39m                                                                                                                                                    \r\u001b[2C\u001b[1B   \u001b[38;5;231m\u001b[2m  6 \u001b[22m\u001b[38;5;149mspec:\u001b[39m                                              \r\r\r\n\u001b[5C\u001b[38;5;231m\u001b[2m \u001b[1C7\u001b[1C\u001b[22m \u001b[1C\u001b[38;5;149mcontainers:\u001b[39m\r\r\r\n\u001b[5C\u001b[38;5;231m\u001b[2m \u001b[1C8\u001b[1C\u001b[22m \u001b[1C-\u001b[1C\u001b[38;5;149mname:\u001b[38;5;231m \u001b[38;5;222mcontainer\u001b[39m\r\r\r\n\u001b[5C\u001b[38;5;231m\u001b[2m \u001b[1C9\u001b[1C\u001b[22m \u001b[3C\u001b[38;5;149mimage:\u001b[38;5;231m \u001b[38;5;222mubuntu:latest\u001b[39m\r\r\r\n\u001b[5C\u001b[38;5;231m\u001b[2m 10\u001b[1C\u001b[22m \u001b[3C\u001b[38;5;149mcommand:\u001b[38;5;231m [\u001b[38;5;222m\"/bin/sh\"\u001b[38;5;231m]\u001b[39m\r\r\r\n\u001b[5C\u001b[38;5;246m…\u001b[1C+16\u001b[1Clines\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[39m\r\r\r\n\r\r\r\n\u001b[38;5;174m✻\u001b[1CIdeating…\u001b[39m\r\r\r\n\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
