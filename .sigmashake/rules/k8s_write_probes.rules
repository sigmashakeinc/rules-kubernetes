# k8s_write_probes.rules — Kubernetes liveness, readiness, and startup probe rules.
# Technology: k8s | Capability: write
# Covers: missing probes, aggressive failure thresholds, hostPort usage, PodDisruptionBudget.

rule no-missing-liveness-probe {
  enabled true
  priority 75
  severity warning
  LOG write
  IF path GLOB "**/*.yaml" AND content CONTAINS "containers:" AND content NOT CONTAINS "livenessProbe:"
  OR path GLOB "**/*.yml" AND content CONTAINS "containers:" AND content NOT CONTAINS "livenessProbe:"
  MESSAGE "No liveness probe defined. Without a liveness probe, Kubernetes cannot restart containers stuck in a deadlock or infinite loop. Add livenessProbe with appropriate httpGet or exec check."
}

rule no-missing-readiness-probe {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*.yaml" AND content CONTAINS "containers:" AND content NOT CONTAINS "readinessProbe:"
  OR path GLOB "**/*.yml" AND content CONTAINS "containers:" AND content NOT CONTAINS "readinessProbe:"
  MESSAGE "No readiness probe defined. Without a readiness probe, Kubernetes routes traffic to pods before they are ready to serve requests. Add readinessProbe to avoid serving errors during startup."
}

rule no-host-port {
  enabled true
  priority 85
  severity warning
  LOG write
  IF path GLOB "**/*.yaml" AND content LINE_REGEX "hostPort:\\s*[0-9]+"
  OR path GLOB "**/*.yml" AND content LINE_REGEX "hostPort:\\s*[0-9]+"
  MESSAGE "hostPort binds the container directly to the host node's port, limiting scheduling to nodes where that port is free and bypassing network policies. Use a Service of type NodePort or LoadBalancer instead."
}

rule no-aggressive-failure-threshold {
  enabled true
  priority 65
  severity warning
  LOG write
  IF path GLOB "**/*.yaml" AND content LINE_REGEX "failureThreshold:\\s*[1-2]$"
  OR path GLOB "**/*.yml" AND content LINE_REGEX "failureThreshold:\\s*[1-2]$"
  MESSAGE "failureThreshold of 1 or 2 may cause unnecessary restarts during transient slowdowns. Consider 3+ for liveness probes to allow the app to recover without a full restart."
}

rule no-single-replica-deployment {
  enabled true
  priority 70
  severity warning
  LOG write
  IF path GLOB "**/*.yaml" AND content CONTAINS "kind: Deployment" AND content LINE_REGEX "replicas:\\s*1$"
  OR path GLOB "**/*.yml" AND content CONTAINS "kind: Deployment" AND content LINE_REGEX "replicas:\\s*1$"
  MESSAGE "Single-replica Deployment has no availability during node maintenance or rolling updates. Set replicas >= 2 for production workloads to maintain uptime during disruptions."
}
